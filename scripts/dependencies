#!/bin/bash

cd "$(cd $(dirname $0)/..; pwd)"

sync_test_utils_dockerfile () {
  local dockerfile="tests/utils/Dockerfile"
  if [[ ! -f "$dockerfile" ]] || [[ ! -f pyproject.toml ]]; then
    return
  fi

  mapfile -t deps < <(sed -ne '/dependencies =/,/\]/p' pyproject.toml | tail -n +2 | head -n -1 | tr -d '",' | xargs -n1)
  if [[ ${#deps[@]} -eq 0 ]]; then
    return
  fi

  local run_block="RUN pip install --no-cache-dir"
  for i in "${!deps[@]}"; do
    if [[ $i -lt $((${#deps[@]} - 1)) ]]; then
      run_block+=$'\n'"    ${deps[$i]} \\"
    else
      run_block+=$'\n'"    ${deps[$i]}"
    fi
  done

  awk -v block="$run_block" '
    /^RUN pip install --no-cache-dir/ { print block; in_deps = 1; replaced = 1; next }
    in_deps && /^[[:space:]]+[A-Za-z0-9_.-]+==/ { next }
    in_deps && /^$/ { print; in_deps = 0; next }
    { print }
    END { if (!replaced) print block }
  ' "$dockerfile" > "${dockerfile}.tmp" && mv "${dockerfile}.tmp" "$dockerfile"
}

check_pkg () {
  local spec="$1"
  local add_after="$2"
  local pkg="${spec%%[=(]*}"
  echo ">>> Checking $pkg..."
  if ! pip freeze | grep -q "^${pkg}=="; then
    pip install $spec --root-user-action=ignore
  else
    pip install "$spec" --upgrade --root-user-action=ignore --quiet
  fi
  if [[ -n "$add_after" ]]; then
    local pinned="$(pip freeze | grep "^${pkg}==")"
    if grep -Eq "$pkg[=(]" pyproject.toml; then
      sed -e "s/$pkg[=(][^\"]*/${pinned}/" -i pyproject.toml
    else
      sed -e "/${add_after}/a\    \"${pinned}\"," -i pyproject.toml
    fi
  fi
}

for spec in \
    "build(>=1.3.0,<2.0.0)" \
    "twine(>=6.2.0,<7.0.0)" \
    "pip-autoremove(>=0.10.0,<1.0.0)" \
    "pytest" \
    "pytest-asyncio" \
    "pytest-cov" \
    "pytest-xdist" \
    "jsonschema" \
; do
  check_pkg "$spec"
done

after="dependencies"
for spec in \
    "paho-mqtt(>=2.1.0,<3.0.0)" \
    "psutil(>=7.0.0,<8.0.0)" \
    "pydantic-settings(>=2.13.1,<3.0.0)" \
    "pymodbus(>=3.9.2,<4.0.0)" \
    "requests(>=2.32.4,<3.0.0)" \
    "ruamel.yaml(>=0.19.1,<1.0.0)" \
; do
  check_pkg "$spec" $after
  pkgs="$pkgs $spec"
  after="${spec%%[=(]*}"
done
for spec in $(sed -ne '/dependencies =/,/\]/p' pyproject.toml | tail -n +2 | head -n -1 | tr -d '",' | xargs); do
  pkg="${spec%%[=(]*}"
  echo "$pkgs" | grep -Eq "$pkg[=(]" || { sed -e "/$pkg[=(]/d" -i pyproject.toml; echo ">>> Removing $pkg"; pip-autoremove $pkg; }
done

sync_test_utils_dockerfile

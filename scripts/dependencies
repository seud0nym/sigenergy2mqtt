#!/bin/bash

cd "$(cd $(dirname $0)/..; pwd)"

update_test_utils_dockerfile () {
  local pkg="$1"
  local pinned="$2"
  local add_after="$3"
  local dockerfile="tests/utils/Dockerfile"
  local pkg_regex="${pkg//./\\.}"
  local add_after_regex="${add_after//./\\.}"
  if [[ ! -f "$dockerfile" ]]; then
    return
  fi

  if grep -Eq "^[[:space:]]+${pkg_regex}==" "$dockerfile"; then
    sed -E -i "s|^([[:space:]]*)${pkg_regex}==[^[:space:]\\\\]+(.*)$|\\1${pinned}\\2|" "$dockerfile"
  elif [[ "$add_after" == "dependencies" ]] || ! grep -Eq "^[[:space:]]+${add_after_regex}==" "$dockerfile"; then
    sed -i "/^RUN pip install --no-cache-dir/a\\
    ${pinned}" "$dockerfile"
  else
    sed -i "/^[[:space:]]*${add_after_regex}==/a\\
    ${pinned}" "$dockerfile"
  fi

  normalize_test_utils_dockerfile_dependencies
}

normalize_test_utils_dockerfile_dependencies () {
  local dockerfile="tests/utils/Dockerfile"
  awk '
    /^RUN pip install --no-cache-dir/ {
      print
      in_deps = 1
      dep_count = 0
      next
    }
    in_deps && /^[[:space:]]+[A-Za-z0-9_.-]+==/ {
      deps[++dep_count] = $0
      next
    }
    in_deps {
      for (i = 1; i <= dep_count; i++) {
        line = deps[i]
        sub(/[[:space:]]*\\[[:space:]]*$/, "", line)
        if (i < dep_count) {
          print line " \\"
        } else {
          print line
        }
      }
      in_deps = 0
      dep_count = 0
    }
    { print }
  ' "$dockerfile" > "${dockerfile}.tmp" && mv "${dockerfile}.tmp" "$dockerfile"
}

remove_from_test_utils_dockerfile () {
  local pkg="$1"
  local dockerfile="tests/utils/Dockerfile"
  local pkg_regex="${pkg//./\\.}"
  if [[ -f "$dockerfile" ]]; then
    sed -E -i "/^[[:space:]]+${pkg_regex}==/d" "$dockerfile"
    normalize_test_utils_dockerfile_dependencies
  fi
}

check_pkg () {
  local spec="$1"
  local add_after="$2"
  local pkg="${spec%%[=(]*}"
  echo ">>> Checking $pkg..."
  if ! pip freeze | grep -q "^${pkg}=="; then
    pip install $spec --root-user-action=ignore
  else
    pip install "$spec" --upgrade --root-user-action=ignore --quiet
  fi
  if [[ -n "$add_after" ]]; then
    local pinned="$(pip freeze | grep "^${pkg}==")"
    if grep -Eq "$pkg[=(]" pyproject.toml; then
      sed -e "s/$pkg[=(][^\"]*/${pinned}/" -i pyproject.toml
    else
      sed -e "/${add_after}/a\    \"${pinned}\"," -i pyproject.toml
    fi
    update_test_utils_dockerfile "$pkg" "$pinned" "$add_after"
  fi
}

for spec in \
    "build(>=1.3.0,<2.0.0)" \
    "twine(>=6.2.0,<7.0.0)" \
    "pip-autoremove(>=0.10.0,<1.0.0)" \
    "pytest" \
    "pytest-asyncio" \
    "pytest-cov" \
    "pytest-xdist" \
    "jsonschema" \
; do
  check_pkg "$spec"
done

after="dependencies"
for spec in \
    "paho-mqtt(>=2.1.0,<3.0.0)" \
    "psutil(>=7.0.0,<8.0.0)" \
    "pydantic-settings(>=2.13.1,<3.0.0)" \
    "pymodbus(>=3.9.2,<4.0.0)" \
    "requests(>=2.32.4,<3.0.0)" \
    "ruamel.yaml(>=0.19.1,<1.0.0)" \
; do
  check_pkg "$spec" $after
  pkgs="$pkgs $spec"
  after="${spec%%[=(]*}"
done
for spec in $(sed -ne '/dependencies =/,/\]/p' pyproject.toml | tail -n +2 | head -n -1 | tr -d '",' | xargs); do
  pkg="${spec%%[=(]*}"
  echo "$pkgs" | grep -Eq "$pkg[=(]" || { sed -e "/$pkg[=(]/d" -i pyproject.toml; remove_from_test_utils_dockerfile "$pkg"; echo ">>> Removing $pkg"; pip-autoremove $pkg; }
done

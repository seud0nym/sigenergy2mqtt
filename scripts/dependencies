#!/bin/bash

cd "$(cd $(dirname $0)/..; pwd)"

update_test_utils_dockerfile () {
  local pkg="$1"
  local pinned="$2"
  local add_after="$3"
  local dockerfile="tests/utils/Dockerfile"
  if [[ -f "$dockerfile" ]]; then
    python - "$dockerfile" "$pkg" "$pinned" "$add_after" <<'PY'
import re
import sys
from pathlib import Path

dockerfile = Path(sys.argv[1])
pkg = sys.argv[2]
pinned = sys.argv[3]
add_after = sys.argv[4]

lines = dockerfile.read_text().splitlines()

run_start = next((i for i, line in enumerate(lines) if line.startswith("RUN pip install --no-cache-dir")), None)
if run_start is None:
    sys.exit(0)

dep_pattern = re.compile(r"^(\s+)([A-Za-z0-9_.-]+)==([^\s\\]+)\s*(\\?)$")
dep_indices: list[int] = []
for idx in range(run_start + 1, len(lines)):
    if dep_pattern.match(lines[idx]):
        dep_indices.append(idx)
    else:
        break

if not dep_indices:
    sys.exit(0)

pkg_index = None
after_index = None
for idx in dep_indices:
    match = dep_pattern.match(lines[idx])
    if match is None:
        continue
    dep_name = match.group(2)
    if dep_name == pkg:
        pkg_index = idx
    if dep_name == add_after:
        after_index = idx

if pkg_index is not None:
    match = dep_pattern.match(lines[pkg_index])
    indent = match.group(1) if match else "    "
    suffix = " \\" if lines[pkg_index].rstrip().endswith("\\") else ""
    lines[pkg_index] = f"{indent}{pinned}{suffix}"
else:
    insert_at = dep_indices[0] if add_after == "dependencies" or after_index is None else after_index + 1
    lines.insert(insert_at, f"    {pinned}")

    # Refresh dependency indices after insertion for continuation normalization.
    dep_indices = []
    for idx in range(run_start + 1, len(lines)):
        if dep_pattern.match(lines[idx]):
            dep_indices.append(idx)
        else:
            break

for idx in dep_indices[:-1]:
    lines[idx] = lines[idx].rstrip().rstrip("\\").rstrip() + " \\"
lines[dep_indices[-1]] = lines[dep_indices[-1]].rstrip().rstrip("\\").rstrip()

dockerfile.write_text("\n".join(lines) + "\n")
PY
  fi
}

check_pkg () {
  local spec="$1"
  local add_after="$2"
  local pkg="${spec%%[=(]*}"
  echo ">>> Checking $pkg..."
  if ! pip freeze | grep -q "^${pkg}=="; then
    pip install $spec --root-user-action=ignore
  else
    pip install "$spec" --upgrade --root-user-action=ignore --quiet
  fi
  if [[ -n "$add_after" ]]; then
    local pinned="$(pip freeze | grep "^${pkg}==")"
    if grep -Eq "$pkg[=(]" pyproject.toml; then
      sed -e "s/$pkg[=(][^\"]*/${pinned}/" -i pyproject.toml
    else
      sed -e "/${add_after}/a\    \"${pinned}\"," -i pyproject.toml
    fi
    update_test_utils_dockerfile "$pkg" "$pinned" "$add_after"
  fi
}

for spec in \
    "build(>=1.3.0,<2.0.0)" \
    "twine(>=6.2.0,<7.0.0)" \
    "pip-autoremove(>=0.10.0,<1.0.0)" \
    "pytest" \
    "pytest-asyncio" \
    "pytest-cov" \
    "pytest-xdist" \
    "jsonschema" \
; do
  check_pkg "$spec"
done

after="dependencies"
for spec in \
    "paho-mqtt(>=2.1.0,<3.0.0)" \
    "psutil(>=7.0.0,<8.0.0)" \
    "pydantic-settings(>=2.13.1,<3.0.0)" \
    "pymodbus(>=3.9.2,<4.0.0)" \
    "requests(>=2.32.4,<3.0.0)" \
    "ruamel.yaml(>=0.19.1,<1.0.0)" \
; do
  check_pkg "$spec" $after
  pkgs="$pkgs $spec"
  after="${spec%%[=(]*}"
done
for spec in $(sed -ne '/dependencies =/,/\]/p' pyproject.toml | tail -n +2 | head -n -1 | tr -d '",' | xargs); do
  pkg="${spec%%[=(]*}"
  echo "$pkgs" | grep -Eq "$pkg[=(]" || { sed -e "/$pkg[=(]/d" -i pyproject.toml; echo ">>> Removing $pkg"; pip-autoremove $pkg; }
done

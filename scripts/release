#!/bin/bash

GREEN='\033[1;32m'
ORANGE='\033[0;33m'
RED='\033[0;31m'
NC='\033[0m' # No Colour

cd "$(cd $(dirname $0)/..; pwd)"
if [[ -z "$VIRTUAL_ENV" ]]; then
   source .venv/bin/activate
fi

git restore sigenergy2mqtt/config/version.py

echo -e "${GREEN}>>> Checking dependencies...${NC}"
scripts/dependencies

source $(dirname $0)/build $*

echo -en "${ORANGE}>>> Confirm version bump? (y/n): ${NC}"
read confirm
if [[ "$confirm" != "y" ]]; then
    echo -e "${RED}>>> Version bump cancelled.${NC}"
    exit 1
fi

echo -e "${GREEN}>>> Bumping version...${NC}"
git add sigenergy2mqtt/config/version.py
git commit -m "build: bump version to $new_version"
git tag "$new_version"
git push && git push --tags

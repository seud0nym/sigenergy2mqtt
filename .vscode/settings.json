        "buildx",
        "cacheonly",
        "cmps",
        "CMUxxxxxxxxxx",
        "CMUyyyyyyyyyy",
        "CONNACK",
        "coro",
        "cutoff",
        "DCCHARGER",
        "Derating",
        "devpub",
        "dockerenv",
        "dotenv",
        "ecowitt2mqtt",
        "elts",
        "emqx",
        "enphase",
        "EVAC",
        "EVDC",
        "fillvalue",
        "forcelist",
        "Gcal",
        "GIGA",
        "gridsensor",
        "HACS",
        "HASS",
        "hassio",
        "healthcheck",
        "homeassistant",
        "HVRT",
        "hwsrc",
        "inet_pton",
        "Initialising",
        "keepalive",
        "kvar",
        "lastindex",
        "levelname",
        "libc",
        "LICEN",
        "lvrt",
        "MAINPID",
        "maxfail",
        "maxsize",
        "Mcal",
        "MILLIWATT",
        "mktime",
        "modbus",
        "modbusregisterdefinitions",
        "Mosquitto",
        "MPPT",
        "mqtt",
        "OVGR",
        "PACKBCUCount",
        "paho",
        "pdst",
        "plantstatistics",
        "popleft",
        "powerplant",
        "preread",
        "proc",
        "propagatable",
        "psutil",
        "PUBACK",
        "PUBCOMP",
        "pvoutput",
        "pvstring",
        "pydantic",
        "pymeth",
        "pymodbus",
        "pypi",
        "pytest",
        "PYTHONUNBUFFERED",
        "rootfs",
        "ruamel",
        "sdist",
        "seud0nym",
        "SIEVDC",
        "sigen",
        "SIGENERGY",
        "SigenStor",
        "signum",
        "SIGUSR",
        "SMARTPORT",
        "SUBACK",
        "teardown",
        "testpaths",
        "tm_isdst",
        "tm_mday",
        "tm_wday",
        "tm_yday",
        "TOCTOU",
        "TPLV",
        "typqxq",
        "uidpub",
        "Unpublishing",
        "UNSUBACK",
        "veth",
        "wordorder",
        "writeonly"
    ],
    "evenBetterToml.formatter.allowedBlankLines": 1,
    "evenBetterToml.formatter.arrayAutoExpand": true,
    "evenBetterToml.formatter.columnWidth": 80,
    "evenBetterToml.formatter.reorderArrays": true,
    "evenBetterToml.formatter.reorderInlineTables": true,
    "evenBetterToml.formatter.reorderKeys": true,
    "python.analysis.diagnosticMode": "workspace",
    "python.defaultInterpreterPath": "${workspaceFolder}/.venv/bin/python",
    "python.languageServer": "None",
    "python.pyrefly.displayTypeErrors": "force-on",
    "python.terminal.activateEnvironment": true,
    "python.testing.pytestArgs": [
        "tests",
        "-n",
        "logical"
    ],
    "python.testing.pytestEnabled": true,
    "python.testing.unittestEnabled": false,
    "ruff.lineLength": 210,
    "terminal.integrated.defaultProfile.linux": "bash",
    "terminal.integrated.shellIntegration.enabled": true,
}